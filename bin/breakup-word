#!/usr/bin/bash

# 分码长,标准格式

if [ -z "$1" ]; then
	echo "Usage: $0 <dictionary_file>"
	echo "dictionary_file format: 编码,序号=字词,频数\n"
	echo "拆分后可以用breakupds-merge合并"
	exit 1
else
	rep="[^,\n]"
	count=1
	while grep -P "^[^,]*,[0-9]*=${rep}(,|\n)" "$1" > breakup${count}.txt; do
		rep="${rep}[^,\n]"
		((count++))
	done

	#尾处理
	rm breakup${count}.txt
fi


